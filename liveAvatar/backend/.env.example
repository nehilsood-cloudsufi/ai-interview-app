LIVEAVATAR_API_KEY=your_heygen_key_here
GEMINI_API_KEY=your_gemini_key_here

# Avatar mode. Dev default: sandbox (free, ~1-min sessions, fixed sandbox
# avatar). For production set SANDBOX_MODE=false AND a real avatar id — the
# sandbox avatar fails outside sandbox mode, and session creation 503s on
# that misconfiguration.
# SANDBOX_MODE=true
# AVATAR_ID=dd73ea75-1218-4ef3-92ce-606d5f7fbc0a

# Required to create avatar sessions: the public URL HeyGen calls back into for
# our LLM gateway (/llm/{interview_id}/v1). In dev, run a tunnel, e.g.
# `cloudflared tunnel --url http://localhost:3001`, and paste its URL here.
# PUBLIC_BASE_URL=https://your-tunnel-host.trycloudflare.com

# Post-interview Data Scout (web research via Gemini + Google Search grounding).
# On by default; set to false to skip research (pipeline still runs).
# SCOUT_ENABLED=false

# Optional: per-domain questionnaires. Directory of {domain}.yaml linear question
# scripts, and which domain POST /api/interview uses when no {domain} is given.
# QUESTIONNAIRES_DIR=data/questionnaires
# DEFAULT_DOMAIN=ai_ml

# Optional: transcript storage backend.
# When GCS_BUCKET is set, finalized interview transcripts + summaries are stored
# in that Google Cloud Storage bucket (blob: transcripts/{session_id}.json),
# using Application Default Credentials. When unset, they are written as local
# JSON files under ./transcripts/ (dev fallback, gitignored).
# GCS_BUCKET=your_bucket_name

# Optional latency polish: stream the Host's reply to HeyGen token-by-token so
# the avatar starts speaking sooner. Off by default; set to true to enable.
# HOST_STREAMING_ENABLED=true
