# All frontend env vars are BUILD-TIME (Vite): they are baked in at `npm run build`.
# In the Docker/Cloud Run deployment, pass them as --build-arg instead (see ../Dockerfile).

# Backend base URL — DEV ONLY (defaults to http://localhost:3001). Production
# builds always use same-origin '' (the backend serves the frontend), ignoring this.
# VITE_API_URL=http://localhost:3001

# Show the vendor their own camera feed during the avatar interview (default: true).
# Set to false to hide the self-view panel AND skip the camera permission prompt.
# VITE_SHOW_SELF_VIEW=false

# Optional link to a spreadsheet listing all interview sessions. Rendered on the
# start screen and summary view only when set.
# VITE_SESSIONS_SHEET_URL=https://docs.google.com/spreadsheets/d/...
